{
  "buildCommand": "bash build.sh",
  "outputDirectory": ".",
  "functions": {
    "api/axp-claude.ts": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/feedback.ts": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "routes": [
    { "handle": "filesystem" },

    { "src": "/bulk-setup/assets/(.*)", "dest": "/apps/bulk-setup/dist/assets/$1" },
    { "src": "/bulk-setup/scrunch-logo.svg", "dest": "/apps/bulk-setup/dist/scrunch-logo.svg" },
    { "src": "/bulk-setup(.*)", "dest": "/apps/bulk-setup/dist/index.html" },

    { "src": "/export/assets/(.*)", "dest": "/apps/scrunch-api-exporter/dist/assets/$1" },
    { "src": "/export/scrunch-logo.svg", "dest": "/apps/scrunch-api-exporter/dist/scrunch-logo.svg" },
    { "src": "/export(.*)", "dest": "/apps/scrunch-api-exporter/dist/index.html" },

    { "src": "/slides/assets/(.*)", "dest": "/apps/google-slides-exporter/dist/assets/$1" },
    { "src": "/slides/scrunch-logo.svg", "dest": "/apps/google-slides-exporter/dist/scrunch-logo.svg" },
    { "src": "/slides(.*)", "dest": "/apps/google-slides-exporter/dist/index.html" },

    { "src": "/analyze/assets/(.*)", "dest": "/apps/response-analyzer-v2/dist/assets/$1" },
    { "src": "/analyze/scrunch-logo.svg", "dest": "/apps/response-analyzer-v2/dist/scrunch-logo.svg" },
    { "src": "/analyze(.*)", "dest": "/apps/response-analyzer-v2/dist/index.html" },

    { "src": "/axp/assets/(.*)", "dest": "/apps/axp-converter/dist/assets/$1" },
    { "src": "/axp/scrunch-logo.svg", "dest": "/apps/axp-converter/dist/scrunch-logo.svg" },
    { "src": "/axp(.*)", "dest": "/apps/axp-converter/dist/index.html" },

    { "src": "/topic-optimizer/assets/(.*)", "dest": "/apps/topic-optimizer/dist/assets/$1" },
    { "src": "/topic-optimizer/scrunch-logo.svg", "dest": "/apps/topic-optimizer/dist/scrunch-logo.svg" },
    { "src": "/topic-optimizer(.*)", "dest": "/apps/topic-optimizer/dist/index.html" },

    { "src": "/scrunch-logo.svg", "dest": "/apps/home/scrunch-logo.svg" },
    { "src": "/(.*)", "dest": "/apps/home/index.html" }
  ]
}
